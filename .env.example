# Telegram bot token from @BotFather
BOT_TOKEN=put_your_telegram_bot_token_here

# Your Telegram numeric ID only. Add more admins comma-separated if needed.
ADMIN_IDS=123456789

# Iraq timezone
TIMEZONE=Asia/Baghdad

# Railway with persistent volume: set DATABASE_PATH=/data/study_commander.sqlite3
# Local default:
DATABASE_PATH=data/study_commander.sqlite3
UPLOADS_DIR=storage/uploads
CERTIFICATES_DIR=storage/certificates

# Optional: deep AI lecture analysis
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Bot signature displayed on weekly certificates
BOT_SIGNATURE=Study Commander Bot

# Subscription warnings
SUBSCRIPTION_GRACE_HOURS=0
