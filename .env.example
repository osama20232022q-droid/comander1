# Telegram
BOT_TOKEN=
ADMIN_IDS=123456789
TIMEZONE=Asia/Baghdad
BOT_SIGNATURE=Study Commander Bot

# Database: preferred for safety is external PostgreSQL.
# Example: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=
# SQLite fallback only if DATABASE_URL is empty:
DATABASE_PATH=/data/study_commander.sqlite3

# Optional OpenAI AI Chat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_CHAT_ENABLED=true
AI_DAILY_LIMIT=30
AI_CONTEXT_MESSAGES=10
AI_MAX_INPUT_CHARS=3500
AI_MAX_OUTPUT_TOKENS=1800
AI_MAX_FILE_CHARS=12000
AI_REQUEST_TIMEOUT=45

# Turbo speed settings
ACCESS_CACHE_TTL=60
ACCESS_CACHE_MAX=20000
BUTTON_CACHE_TTL=300
BOT_CONCURRENT_UPDATES=64
TG_CONNECTION_POOL_SIZE=64
TG_POOL_TIMEOUT=10
TG_READ_TIMEOUT=20
TG_WRITE_TIMEOUT=20
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=20
DB_POOL_RECYCLE=1800
PRAYER_JOB_INTERVAL=60
PRAYER_REMOTE_TIMEOUT=2

# Backups are admin-only. Telegram backup export works without extra services.
BACKUP_KEEP_DAYS=30
