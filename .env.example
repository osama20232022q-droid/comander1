# =========================
# Telegram
# =========================
BOT_TOKEN=
ADMIN_IDS=123456789
TIMEZONE=Asia/Baghdad
BOT_SIGNATURE=Study Commander Bot
ENVIRONMENT=production

# =========================
# Database
# Railway PostgreSQL is preferred for production.
# Railway normally supplies DATABASE_URL automatically when linked.
# =========================
DATABASE_URL=
DATABASE_PATH=/data/study_commander.sqlite3
SQLITE_TIMEOUT=30
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=20
DB_POOL_RECYCLE=1800

# =========================
# Gemini AI
# =========================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/interactions
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-3-flash-preview,gemini-2.5-flash
AI_CHAT_ENABLED=true
AI_MAX_RETRIES_PER_MODEL=2
AI_RETRY_BACKOFF_SECONDS=2
AI_DAILY_LIMIT=30
AI_CONTEXT_MESSAGES=10
AI_MAX_INPUT_CHARS=3500
AI_MAX_OUTPUT_TOKENS=1800
AI_MAX_FILE_CHARS=12000
AI_MAX_FILE_BYTES=8388608
AI_REQUEST_TIMEOUT=90

# =========================
# Telegram networking and flow safety
# Keep 1 unless you fully understand concurrent multi-step conversations.
# =========================
BOT_CONCURRENT_UPDATES=1
TG_CONNECTION_POOL_SIZE=16
TG_POOL_TIMEOUT=20
TG_READ_TIMEOUT=30
TG_WRITE_TIMEOUT=30

# Inbound anti-spam controls per user
INBOUND_LIMIT_COUNT=18
INBOUND_LIMIT_WINDOW_SECONDS=20
INBOUND_BLOCK_SECONDS=20

# =========================
# Backups
# Generate a key with:
# python -m app.tools.generate_backup_key
# Store the generated key only in Railway Variables, never GitHub.
# =========================
BACKUP_KEEP_DAYS=30
BACKUP_ENCRYPTION_KEY=
REQUIRE_ENCRYPTED_BACKUPS=false

# Other services
ACCESS_CACHE_TTL=60
ACCESS_CACHE_MAX=20000
BUTTON_CACHE_TTL=300
PRAYER_JOB_INTERVAL=60
PRAYER_REMOTE_TIMEOUT=2
